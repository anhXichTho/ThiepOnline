rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cards/{cardId} {
      allow read: if true;
      allow create: if request.resource.data.keys()
        .hasAll(['type','content','createdAt']);

      match /rsvp/{rsvpId} {
        allow read, create: if true;
      }
    }

    // Danh sách tên người dùng được cấp bởi admin.
    // ưu tí: ai cũng có thể đọc (để verify tên), nhưng ghi/xóa không bị hạn chế
    //         vì auth admin là client-side. Cho production nên thêm Firebase Auth.
    match /users/{userId} {
      allow read, write: if true;
    }

    // Photo queue — lượt chụp ảnh lễ trưởng thành
    match /photo_queue/{entryId} {
      allow read, create: if true;
      allow update: if true;
    }

    // Queue state — trạng thái hiện tại của hàng chờ
    match /settings/{docId} {
      allow read, write: if true;
    }
  }
}
